# GA ERP System - Environment Variables
# Copy this file to .env and fill in the values

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL=postgresql://user:password@localhost:5432/gaerp
# For SQLite (development only):
# DATABASE_URL=sqlite:///./gaerp.db

# ===========================================
# JWT SECURITY
# ===========================================
# Generate a secure secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===========================================
# SERVER
# ===========================================
HOST=0.0.0.0
PORT=8000
DEBUG=false

# ===========================================
# CORS (Comma-separated list of allowed origins)
# ===========================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# ===========================================
# AFIP/ARCA ELECTRONIC INVOICING
# ===========================================
AFIP_AMBIENTE=testing  # testing or production
AFIP_CERT_PATH=/app/certs/certificado.pem
AFIP_KEY_PATH=/app/certs/clave_privada.key

# ===========================================
# BACKUP
# ===========================================
BACKUP_PATH=/backups
BACKUP_RETENTION_DAYS=30

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_LOGIN_PER_MINUTE=5
