# =============================================================================
# GA ERP - Desktop ERP Configuration
# =============================================================================
# SQLite is the default - no installation required!
# To use PostgreSQL: DATABASE_URL=postgresql://user:password@host/dbname

# Database (SQLite default for desktop - no setup needed)
DATABASE_URL=sqlite:///./carpinteria.db

# JWT Configuration
JWT_SECRET_KEY=ga-erp-secret-key-local-desktop-erp
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Server
DEBUG=True

# CORS - Allow local development
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000,http://tauri.localhost

# Electronic Invoicing (ARCA/AFIP)
# Mode: "mock" (default, no ARCA needed) or "real" (requires credentials)
AFIP_MODE=mock
AFIP_AMBIENTE=testing

# Optional: Uncomment and fill to enable real ARCA invoicing
# AFIP_MODE=real
# AFIP_CERT_PATH=/path/to/certificate.pem
# AFIP_KEY_PATH=/path/to/private.key
# AFIP_CUIT=20123456789

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_LOGIN_PER_MINUTE=5