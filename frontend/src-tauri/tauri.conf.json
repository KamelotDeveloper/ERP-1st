{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "El Menestral ERP",
  "version": "1.1.0",
  "identifier": "com.menestral.erp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "El Menestral - Sistema de Gestión ERP",
        "width": 1280,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../../backend/dist/ga-erp-backend.exe"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "publisher": "Carpinteria El Menestral",
    "shortDescription": "Sistema ERP para Carpintería",
    "longDescription": "Sistema de gestión ERP completo para Carpintería El Menestral con facturación electrónica ARCA/AFIP"
  }
}