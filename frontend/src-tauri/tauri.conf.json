{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "El Menestral ERP",
  "version": "1.1.0",
  "identifier": "com.menestral.erp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "El Menestral - Sistema de Gestión ERP",
        "width": 1280,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' http://127.0.0.1:8000 https://suscripcion-api-kc5t.vercel.app http://tauri.localhost http://localhost:5173 http://localhost:3000 ipc://localhost http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg"],
    "resources": [],
    "externalBin": [
      "./binaries/ga-erp-backend"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "publisher": "Carpinteria El Menestral",
    "shortDescription": "Sistema ERP para Carpintería",
    "longDescription": "Sistema de gestión ERP completo para Carpintería El Menestral con facturación electrónica ARCA/AFIP"
  }
}