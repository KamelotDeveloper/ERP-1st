{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "El Menestral ERP",
  "version": "1.1.0",
  "identifier": "com.menestral.erp",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "El Menestral - Sistema de Gestión ERP",
        "width": 1280,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' http://127.0.0.1:8000 http://tauri.localhost http://localhost:5173 http://localhost:3000"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "../../backend/main.py": "backend/main.py",
      "../../backend/models.py": "backend/models.py",
      "../../backend/schemas.py": "backend/schemas.py",
      "../../backend/database.py": "backend/database.py",
      "../../backend/config.py": "backend/config.py",
      "../../backend/requirements.txt": "backend/requirements.txt",
      "../../backend/alembic": "backend/alembic",
      "../../backend/alembic.ini": "backend/alembic.ini",
      "../../backend/.env": "backend/.env",
      "../../backend/routers": "backend/routers",
      "../../backend/services": "backend/services",
      "../../backend/certs": "backend/certs"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "publisher": "Carpinteria El Menestral",
    "shortDescription": "Sistema ERP para Carpintería",
    "longDescription": "Sistema de gestión ERP completo para Carpintería El Menestral con facturación electrónica ARCA/AFIP"
  }
}