{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "El Menestral ERP",
  "version": "1.1.0",
  "identifier": "com.menestral.erp",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "El Menestral - Sistema de Gestión ERP",
        "width": 1280,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "center": true,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": [
      "../../backend/main.py",
      "../../backend/models.py",
      "../../backend/schemas.py",
      "../../backend/database.py",
      "../../backend/config.py",
      "../../backend/routers/*",
      "../../backend/services/*",
      "../../backend/requirements.txt",
      "../../backend/.env",
      "../../backend/alembic/*"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}